hub959.ru, www.hub959.ru {
    # Static files and Vue Router history mode
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }

    # Proxy API to Django
    handle /api/* {
        reverse_proxy django:8000
    }

    # Proxy auth to Django
    handle /auth/* {
        reverse_proxy django:8000
    }

    # Proxy WebSocket